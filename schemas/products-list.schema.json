{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["quantidade", "produtos"],
  "properties": {
    "quantidade": { "type": "integer", "minimum": 0 },
    "produtos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["_id"],
        "properties": {
          "_id": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
