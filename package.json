{
  "name": "serverest-api-playwright-automation",
  "version": "1.0.0",
  "private": true,
  "description": "API test suite for ServeRest using Playwright",
  "author": "Bruno Salzani",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "report:allure": "allure generate --clean ./allure-results && allure open",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"tests/**/*.ts\" --max-warnings=0",
    "drift:check": "node ./scripts/drift-detect.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.13.10",
    "ajv": "^8.17.1",
    "allure-commandline": "^2.29.0",
    "allure-playwright": "^2.15.1",
    "zod": "^3.22.4",
    "dotenv": "^16.4.5",
    "typescript": "^5.6.3",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-unused-imports": "^4.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.2.5",
    "husky": "^9.0.11",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
